# PostgreSQL connection (replace with your actual password or Railway URL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/dct_db

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-char-hex-string

# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# Get from https://console.cloud.google.com → YouTube Data API v3 (optional)
YOUTUBE_API_KEY=AIzaSy-xxxx

PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
